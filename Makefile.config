# Shared configuration for project makefiles.

# Project root is resolved from this file location.
PROJECT_ROOT ?= $(abspath $(dir $(lastword $(MAKEFILE_LIST))))

# Toolchain
CC ?= gcc
CPPFLAGS ?=
CFLAGS ?= -std=c11 -Wall -Wextra -Wpedantic -O2
LDFLAGS ?=
LDLIBS ?= -lsodium

# Layout
SRC_DIR ?= $(PROJECT_ROOT)/src
DEMONSTRATIONS_DIR ?= $(PROJECT_ROOT)/demostrations
BUILD_DIR ?= $(DEMONSTRATIONS_DIR)/.build
TEMP_DIR ?= $(PROJECT_ROOT)/.temp
